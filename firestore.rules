rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default fallback: deny all operations
    match /{document=**} {
      allow read, write: if false;
    }

    // Survey Responses: Allow read and write for survey entries and live dashboard syncing
    match /responses/{responseId} {
      allow read, write: if true;
    }
  }
}
